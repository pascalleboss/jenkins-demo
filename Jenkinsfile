pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Code récupéré depuis GitHub'
            }
        }

        stage('Build') {
            steps {
                echo 'Compilation en cours'
            }
        }

        stage('Test') {
            steps {
                echo 'Tests exécutés'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Déploiement simulé'
            }
        }
    }
}