pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Code récupéré depuis Git'
            }
        }

        stage('Build') {
            steps {
                echo 'Compilation'
            }
        }

        stage('Test') {
            steps {
                echo 'Tests exécutés'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Déploiement simulé'
            }
        }
    }
}
